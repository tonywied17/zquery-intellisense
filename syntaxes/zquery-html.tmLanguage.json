{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "zQuery HTML Interpolation",
  "scopeName": "zquery.html.interpolation",
  "injectionSelector": "L:text.html -comment",
  "patterns": [
    { "include": "#interpolation" }
  ],
  "repository": {
    "interpolation": {
      "name": "meta.interpolation.zquery",
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.zquery" }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.zquery" }
      },
      "contentName": "meta.embedded.expression.zquery",
      "patterns": [
        {
          "name": "constant.language.boolean.zquery",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.zquery",
          "match": "\\b(?:null|undefined)\\b"
        },
        {
          "name": "constant.numeric.decimal.zquery",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        },
        {
          "name": "string.quoted.single.zquery",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.quoted.double.zquery",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "keyword.operator.comparison.zquery",
          "match": "===?|!==?"
        },
        {
          "name": "keyword.operator.logical.zquery",
          "match": "&&|\\|\\||\\?\\?"
        },
        {
          "name": "keyword.operator.relational.zquery",
          "match": "[<>]=?"
        },
        {
          "name": "keyword.operator.ternary.zquery",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.arithmetic.zquery",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.logical.not.zquery",
          "match": "!"
        },
        {
          "name": "punctuation.accessor.zquery",
          "match": "\\."
        },
        {
          "name": "variable.other.readwrite.zquery",
          "match": "\\b[a-zA-Z_$][\\w$]*\\b"
        }
      ]
    }
  }
}
